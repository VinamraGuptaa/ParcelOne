# ── eCourts Scraper — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# .env is loaded automatically by server.py via python-dotenv.

# Database connection URL
# --- Local dev (SQLite, no setup required) ---
DATABASE_URL=sqlite+aiosqlite:///./ecourts.db

# --- Supabase PostgreSQL (production) ---
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# CORS origins — comma-separated list of allowed frontend origins.
# Use "*" to allow all (fine for local dev; restrict in production).
CORS_ORIGINS=*

# --- Production example ---
# CORS_ORIGINS=https://myapp.netlify.app,https://myapp.vercel.app

# Set to "1" to enable uvicorn hot-reload (local dev only)
DEV=1

# How many completed jobs to retain in the DB (older ones are deleted after each run).
# Increase this if you want a longer history. Default: 10
MAX_JOBS=10

# Override the dynamic scrape timeout (seconds). By default the timeout is
# calculated as max(120, num_years × 90s) — e.g. 1 year=120s, 15 years=1350s.
# Set this only if you need a hard cap regardless of year count.
# SCRAPE_TIMEOUT_SECONDS=1200
