# ── icy-disk — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is loaded automatically by server.py via python-dotenv.

# Database connection URL
# --- Local dev (SQLite, no setup required) ---
DATABASE_URL=sqlite+aiosqlite:///./ecourts.db

# --- AWS RDS PostgreSQL (production) ---
# DATABASE_URL=postgresql+asyncpg://user:password@your-rds-endpoint.region.rds.amazonaws.com:5432/icy_disk

# CORS origins — comma-separated list of allowed frontend origins.
# Use "*" for local dev. On AWS, set your ALB/CloudFront URL when frontend is split.
CORS_ORIGINS=*

# --- AWS production example (same-origin Docker deploy: leave as * or omit) ---
# CORS_ORIGINS=https://icy-disk.example.com

# ── React frontend (frontend/) ──────────────────────────────────────────────
# Vite dev proxy target (local FastAPI). Default: http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000
#
# API path inside the React app. Docker build sets VITE_API_BASE=/api (same-origin).
# Leave unset for same-origin AWS deploy (FastAPI serves frontend/dist + /api).
# VITE_API_BASE=/api

# Set to "1" to enable uvicorn hot-reload (local dev only)
DEV=1

# HTTP port (ECS/Fargate task definition maps containerPort 8000)
PORT=8000

# How many completed jobs to retain in the DB (older ones are deleted after each run).
MAX_JOBS=10

# Playwright browser cache for Bhulekh / IGR / eCourts scrapers.
PLAYWRIGHT_BROWSERS_PATH=./.playwright-browsers
# PLAYWRIGHT_ALLOW_SYSTEM_EXECUTABLE=1
# PLAYWRIGHT_AUTO_INSTALL=1

# IGR search timing (seconds). Remove IGR_RESULTS_WAIT_SECONDS=120 on prod if set — it makes empty years take 2 min each.
# IGR_RESULTS_WAIT_SECONDS=45
# IGR_PENDING_STALL_SECONDS=20
# IGR_PARALLEL_CONTEXTS=1
# IGR_SAVE_RAW_HTML=1

# Override the dynamic scrape timeout (seconds).
# SCRAPE_TIMEOUT_SECONDS=1200

# eCourts API key (required for API mode; must start with eci_)
# ECOURTS_API_KEY=eci_your_real_key_here

# Enable fallback to scraper when API key is missing/invalid.
# ECOURTS_ALLOW_SCRAPER_FALLBACK=1

# eCourts API search optimization filters
# ECOURTS_API_SEARCH_PAGE_SIZE=20
# ECOURTS_API_CASE_STATUSES=PENDING
# ECOURTS_API_CASE_TYPES=
